# Cylix website — required environment variables
#
# Copy this file to .env (for local dev) and fill in real values.
# In production (Vercel/Netlify/etc.), set these in your hosting
# provider's "Environment Variables" dashboard — never commit real
# secrets to git.

# Gmail account used to send/receive order + contact emails
GMAIL_USER=cylixteam05@gmail.com

# A Gmail "App Password" (NOT your normal Gmail login password).
# To generate one:
#   1. Go to https://myaccount.google.com/security
#   2. Turn on 2-Step Verification (required for App Passwords to exist)
#   3. Go to https://myaccount.google.com/apppasswords
#   4. Create one for "Mail" / "Other (Cylix Website)"
#   5. Paste the 16-character password below (no spaces)
GMAIL_APP_PASSWORD=
